# Purpose: Backend-specific environment template for the ChatterBox Express and Socket.io service.

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

MONGO_URI=mongodb://localhost:27017/chatterbox
MONGO_TEST_URI=mongodb://127.0.0.1:27017/chatterbox_test
MONGO_MAX_POOL_SIZE=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=chatterbox-messages

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
MESSAGE_HISTORY_LIMIT=50
ONLINE_USER_TTL_SECONDS=3600
MESSAGE_CACHE_TTL_SECONDS=86400
