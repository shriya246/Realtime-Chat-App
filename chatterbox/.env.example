# Purpose: Shared environment template for running ChatterBox locally or in containers.

NODE_ENV=development
CLIENT_PORT=3000
SERVER_PORT=5000
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12

MONGO_URI=mongodb://mongo:27017/chatterbox
MONGO_TEST_URI=mongodb://127.0.0.1:27017/chatterbox_test
MONGO_INITDB_DATABASE=chatterbox
MONGO_MAX_POOL_SIZE=10
MONGO_PORT=27017

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLIC_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
# Optional comma-separated managed cluster startup nodes: host-a:6379,host-b:6379
REDIS_CLUSTER_NODES=

# Local no-op is the default free event publisher. Set to azure only if you bring your own Azure Service Bus.
EVENT_PUBLISHER=noop
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=chatterbox-messages

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
MESSAGE_HISTORY_LIMIT=50
ONLINE_USER_TTL_SECONDS=3600
MESSAGE_CACHE_TTL_SECONDS=86400
JSON_BODY_LIMIT=1mb
COMPRESSION_THRESHOLD_BYTES=1024
UPLOAD_DIR=uploads
MAX_UPLOAD_FILE_SIZE_BYTES=10485760
TRUST_PROXY=false
SHUTDOWN_TIMEOUT_MS=10000
